{
  "$schema": "https://raw.githubusercontent.com/spetersenms/AL-Go/CodeCoverage/Actions/.Modules/settings.schema.json",
  "type": "PTE",
  "templateUrl": "https://github.com/spetersenms/AL-Go@CodeCoverage",
  "generateDependencyArtifact": true,
  "DeployToProduction": {
    "environmentName": "AL-Go-Demo-Test"
  },
  "templateSha": "48106a4496920fff5aa6161689b11b0888045aab",
  "enableCodeCop": true,
  "enableUICop": true,
  "rulesetFile": "../rulesets/ruleset.json",
  "trackAlAlertsInGitHub": true,
  "useProjectDependencies": true,
  "buildModes": [],
  "artifact": "//26//latest",
  "enableCodeCoverage": true,
  "codeCoverageSetup": {
      "trackingType": "PerRun",
      "produceCodeCoverageMap": "PerCodeunit",
      "excludeFilesPattern": ["*.PermissionSet.al"]
  }
}
